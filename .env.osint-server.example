# Keep this value server-side. Do not prefix it with VITE_.
VT_API_KEY=your_virustotal_v3_api_key

# The Vite development server is allowed by default. Add deployed UI origins as
# a comma-separated list when the OSINT server is hosted separately.
OSINT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OSINT_SERVER_HOST=127.0.0.1
OSINT_SERVER_PORT=8787

# Set this in the frontend environment only when the OSINT server is deployed
# at a different public URL. Never expose VT_API_KEY to the browser.
# VITE_OSINT_API_URL=https://osint-api.example.com
